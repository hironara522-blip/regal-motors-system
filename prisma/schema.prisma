generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id                    String    @id @default(cuid())
  registrationNumber    String?   // 自動車登録番号（ナンバープレート）
  chassisNumber         String?   // 車台番号
  modelCode             String?   // 型式
  manufacturer          String?   // メーカー
  carName               String?   // 車名
  firstRegistrationDate String?   // 初度登録年月 (例: "2020年3月")
  inspectionExpiry      DateTime? // 車検満了日
  displacement          Int?      // 排気量 (cc)
  fuel                  String?   // 燃料種類
  bodyType              String?   // 車体の形状
  vehicleType           String?   // 自動車の種別
  capacity              Int?      // 乗車定員
  vehicleWeight         Int?      // 車両重量 (kg)
  engineModel           String?   // 原動機型式
  color                 String?   // 色
  mileage               Int?      // 走行距離 (km)
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  appraisals   Appraisal[]
  images       VehicleImage[]
}

model Appraisal {
  id                String          @id @default(cuid())
  vehicleId         String
  status            AppraisalStatus @default(IN_PROGRESS)
  exteriorGrade     Grade?          // 外装総合等級
  interiorGrade     Grade?          // 内装総合等級
  hasRepairHistory  Boolean         @default(false) // 修復歴
  hasInspectionBook Boolean         @default(false) // 整備記録簿
  hasManual         Boolean         @default(false) // 取扱説明書
  hasSpareKey       Boolean         @default(false) // スペアキー
  totalScore        Float?          // 総合評価点
  purchasePrice     Int?            // 買取価格（円）
  marketPriceMin    Int?            // 相場価格下限（円）
  marketPriceMax    Int?            // 相場価格上限（円）
  appraiserName     String?         // 査定担当者名
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  vehicle Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  items   AppraisalItem[]
}

model AppraisalItem {
  id           String          @id @default(cuid())
  appraisalId  String
  category     ItemCategory    // カテゴリ
  itemName     String          // 部位・項目名
  condition    ItemCondition   @default(GOOD) // 状態
  notes        String?

  appraisal Appraisal @relation(fields: [appraisalId], references: [id], onDelete: Cascade)
}

model VehicleImage {
  id        String   @id @default(cuid())
  vehicleId String
  path      String   // ファイルパス
  type      String?  // "registration_cert" | "exterior" | "interior" etc.
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

enum AppraisalStatus {
  IN_PROGRESS // 査定中
  COMPLETED   // 査定完了
  PURCHASED   // 買取済み
  DECLINED    // 見送り
}

enum Grade {
  S  // 特上
  A  // 上
  B  // 中
  C  // 下
  D  // 要整備
}

enum ItemCategory {
  EXTERIOR    // 外装
  INTERIOR    // 内装
  MECHANICAL  // 機関系
  ACCESSORY   // 付属品
  TIRE        // タイヤ・ホイール
}

enum ItemCondition {
  GOOD        // 良好
  NORMAL      // 普通
  NEEDS_WORK  // 要整備
  POOR        // 不良
}
